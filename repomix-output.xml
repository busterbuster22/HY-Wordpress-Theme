}

@media (min-width: 769px) {
  .content-container {
    padding-left: var(--wp--custom--spacing--outer) !important;
    padding-right: var(--wp--custom--spacing--outer) !important;
  }
}
/* ========================================
   LAYOUT & CONTAINERS
   ======================================== */
.wp-site-blocks {
  width: 100%;
  max-width: 100%;
}

/* Constrain content inside full-width sections */
.full-width-homepage .wp-block-columns,
.full-width-homepage > .wp-block-heading,
.full-width-homepage > .wp-block-paragraph,
.full-width-homepage > .petition-row,
.full-width-homepage > .content-container {
  max-width: var(--wp--style--global--wide-size, 1400px);
  margin-left: auto !important;
  margin-right: auto !important;
  padding-left: 20px !important;
  padding-right: 20px !important;
  box-sizing: border-box !important;
}

/* Content sections with vertical spacing */
.content-section {
  padding-block: var(--wp--custom--spacing--small);
}

/* Column spacing */
.wp-block-columns {
  gap: var(--wp--style--block-gap, 0.5em);
}

.wp-block-column {
  padding-inline: 0;
}

/* Header background */
header.wp-block-template-part {
  background-color: var(--wp--preset--color--ash-grey, #2D2A2E);
  color: var(--wp--preset--color--white, #FFFFFF);
}

/* Header text colors */
header.wp-block-template-part h1,
header.wp-block-template-part h2,
header.wp-block-template-part h3,
header.wp-block-template-part h4,
header.wp-block-template-part h5,
header.wp-block-template-part h6,
header.wp-block-template-part p,
header.wp-block-template-part a {
  color: var(--wp--preset--color--white, #FFFFFF);
}

/* Apply container styling to header columns - MOBILE FIRST */
header.wp-block-template-part .wp-block-columns.header-columns {
  max-width: var(--wp--style--global--wide-size, 1400px);
  margin-left: auto !important;
  margin-right: auto !important;
  padding-left: 20px !important;
  padding-right: 20px !important;
  box-sizing: border-box !important;
  width: 100% !important;
}

/* Remove padding from individual columns */
header.wp-block-template-part .wp-block-column {
  padding-left: 0 !important;
  padding-right: 0 !important;
}

/* DESKTOP OVERRIDE - must come after mobile rules */
@media (min-width: 769px) {
  header.wp-block-template-part .wp-block-columns.header-columns {
    padding-left: var(--wp--custom--spacing--outer) !important;
    padding-right: var(--wp--custom--spacing--outer) !important;
  }
}
/* Footer gets constrained content - matches body and header */
footer.wp-block-template-part {
  width: 100%;
  max-width: 100%;
  margin-top: var(--wp--custom--gap--vertical);
}

/* Constrain footer content inside the full-width background */
footer.wp-block-template-part .wp-block-columns,
footer.wp-block-template-part .wp-block-paragraph {
  max-width: var(--wp--style--global--wide-size, 1400px);
  margin-left: auto !important;
  margin-right: auto !important;
  padding-left: 20px !important;
  padding-right: 20px !important;
  box-sizing: border-box !important;
}

header.wp-block-template-part .wp-block-column {
  padding-left: 0 !important;
  padding-right: 0 !important;
}

/* Remove any extra spacing from header-columns specifically */
.header-columns {
  padding-left: 0 !important;
  padding-right: 0 !important;
  margin-left: 0 !important;
  margin-right: 0 !important;
}

/* Footer gets constrained content - matches body and header */
footer.site-footer-container {
  width: 100%;
  max-width: 100%;
}

footer.site-footer-container > .wp-block-group {
  max-width: var(--wp--style--global--wide-size, 1400px);
  margin: 0 auto;
  padding-left: 20px;
