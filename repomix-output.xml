/* =========================================================================
   SURVEY FORM (form.new_response) — AN v6/survey widget
   Mirrors form.new_answer styling. Loaded on pages using the "survey"
   block template via action-survey-embed.js + this CSS.
   ========================================================================= */

/* === GLOBAL FORM LAYOUT === */
#can_embed_form form.new_response {
    background: none !important;
    border: none !important;
    padding: 0 !important;
    margin: 0 !important;
    font-family: var(--wp--preset--font-family--inter) !important;
}

/* === HEADINGS === */
#can_embed_form form.new_response h2,
#can_embed_form form.new_response h3,
#can_embed_form form.new_response h4 {
    font-family: var(--wp--preset--font-family--league-spartan) !important;
    font-weight: 700 !important;
    color: #000000 !important;
    border-bottom: none !important;
    text-shadow: none !important;
}

/* === INPUT FIELDS (House You Shadow-Box Style) === */
#can_embed_form form.new_response input[type="text"],
#can_embed_form form.new_response input[type="email"],
#can_embed_form form.new_response input[type="tel"],
#can_embed_form form.new_response textarea {
    font-family: var(--wp--preset--font-family--inter) !important;
    font-size: 18px !important;
    height: 52px !important;
    padding: 12px 15px !important;
    border-radius: 10px !important;
    border: 2px solid #2D2A2E !important;
    box-shadow: 10px 10px 0px 0px #2D2A2E !important;
    background: #FFFFFF !important;
    color: #000000 !important;
    width: 100% !important;
    display: block !important;
    box-sizing: border-box !important;
    margin-bottom: 20px !important;
}

/* Textarea specific */
#can_embed_form form.new_response textarea {
    height: auto !important;
    min-height: 120px !important;
}

/* Placeholder styling */
#can_embed_form form.new_response ::placeholder {
    color: rgba(0, 0, 0, 0.5) !important;
    opacity: 1 !important;
}

/* === SUBMIT BUTTON (House You Pink Style) === */
#can_embed_form form.new_response input[type="submit"],
#can_embed_form form.new_response .button,
#can_embed_form form.new_response .can_button {
    background-color: #CB1EAA !important;
    color: #FFFFFF !important;
    font-family: var(--wp--preset--font-family--league-spartan) !important;
    font-weight: 700 !important;
    font-size: 20px !important;
    text-transform: uppercase !important;
    border: none !important;
    border-radius: 11px !important;
    padding: 12px 32px !important;
    box-shadow: 10px 10px 2px 0 #2D2A2E !important;
    cursor: pointer !important;
    display: block !important;
    margin: 20px auto 0 auto !important;
    width: auto !important;
}

#can_embed_form form.new_response input[type="submit"]:hover,
#can_embed_form form.new_response .button:hover,
#can_embed_form form.new_response .can_button:hover {
    background-color: #A01888 !important;
}

/* === TWO-COLUMN LAYOUT === */
#can_embed_form form.new_response #form_col1 {
    display: flex !important;
    flex-wrap: wrap !important;
    justify-content: space-between !important;
    width: 100% !important;
    float: none !important;
}

#can_embed_form form.new_response #form_col1 li.core_field,
#can_embed_form form.new_response #form_col1 li.control-group.js-fb-textinput {
    width: 48% !important;
    flex: 0 0 48% !important;
