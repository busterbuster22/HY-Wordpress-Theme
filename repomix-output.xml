#can_embed_form form.new_response #d_sharing ul,
#can_embed_form form.new_response #d_sharing li {
    list-style: none !important;
    padding: 0 !important;
}

#can_embed_form form.new_response #d_sharing label {
    color: #000000 !important;
    font-size: 20px !important;
    font-weight: bold !important;
    display: flex !important;
    align-items: center !important;
    gap: 8px !important;
}

/* === FLOATLABEL === */
#can_embed_form form.new_response .floatlabel-wrapper {
    position: relative !important;
    display: block !important;
}

/* === HIDE EMPTY FORM BUILDER OUTPUT === */
#can_embed_form form.new_response li.form_builder_output.js-form_builder_output {
    display: none !important;
}

/* === HIDE AN BRANDING === */
#can_embed_form form.new_response .ajax-loading,
#can_embed_form form.new_response .international_link-wrap,
#can_embed_form form.new_response .country_drop_wrap,
#can_embed_form form.new_response #logo_wrap,
#can_embed_form form.new_response .can_help_text {
    display: none !important;
}

