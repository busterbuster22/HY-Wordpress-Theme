/* Question labels */
#can_embed_form #survey_questions li.control-group label.check_radio_label,
#can_embed_form #survey_questions li.control-group label.control-label {
    font-size: 18px !important;
    font-weight: bold !important;
    color: #000000 !important;
    margin-bottom: 8px !important;
    display: block !important;
}

/* Textarea styling */
#can_embed_form #survey_questions textarea {
    border: 2px solid #2D2A2E !important;
    box-shadow: 10px 10px 0px 0px #2D2A2E !important;
    border-radius: 10px !important;
    padding: 12px 15px !important;
    width: 100% !important;
    box-sizing: border-box !important;
    min-height: 100px !important;
    font-size: 16px !important;
    margin-bottom: 20px !important;
}

/* Submit button (uses <button class="button">) */
#can_embed_form #survey_questions_footer button.button {
    background-color: #CB1EAA !important;
    color: #FFFFFF !important;
    font-family: var(--wp--preset--font-family--league-spartan) !important;
    font-weight: 700 !important;
    font-size: 20px !important;
    line-height: 1 !important;
    text-transform: uppercase !important;
    border: none !important;
    border-radius: 11px !important;
    padding: 12px 32px !important;
    box-shadow: 10px 10px 2px 0 #2D2A2E !important;
    cursor: pointer !important;
    display: block !important;
    margin: 20px auto 0 auto !important;
    vertical-align: middle !important;
}

/* Hide progress bar (single-page survey has no meaningful progress) */
#can_embed_form #survey_progress_wrap {
    display: none !important;
}

/* Radio/checkbox option labels */
#can_embed_form #survey_questions label.radio,
#can_embed_form #survey_questions label.checkbox {
    display: flex !important;
    align-items: center !important;
    gap: 8px !important;
    font-size: 16px !important;
    color: #000000 !important;
    margin-bottom: 6px !important;
}

/* === SURVEY THANK-YOU PAGE === */
/* Show only "Thanks for your support." — hide all sharing/social blocks */
#can_embed_form.can_thank_you_wrap .can_thank_you-block,
#can_embed_form.can_thank_you_wrap .clearfix > .can_thank_you-block {
    display: none !important;
}

#can_embed_form.can_thank_you_wrap #can_thank_you h4 {
    display: none !important;
}

#can_embed_form.can_thank_you_wrap #action_info {
    display: none !important;
}

#can_embed_form.can_thank_you_wrap #logo_wrap {
    display: none !important;
}

#can_embed_form.can_thank_you_wrap #can_thank_you h1 {
    font-family: var(--wp--preset--font-family--league-spartan) !important;
    font-size: 32px !important;
    font-weight: 700 !important;
    color: #000000 !important;
}

/* Hide the entire clearfix wrapper containing sharing blocks */
#can_embed_form.can_thank_you_wrap .clearfix:has(.can_thank_you-block) {
    display: none !important;
}
