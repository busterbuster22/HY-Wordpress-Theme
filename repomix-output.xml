/* =========================================================================
   EVENTS LISTING SHORTCODE
   ========================================================================= */
.events-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 25px;
  justify-content: center;
}
@media (min-width: 769px) {
  .events-grid {
    max-width: var(--events-grid-max-width, none);
    margin-left: auto;
    margin-right: auto;
  }
}
@media (min-width: 769px) {
  .events-grid--columned {
    display: grid;
    grid-template-columns: repeat(var(--events-grid-columns, 3), 1fr);
    max-width: none;
  }
}

.event-card-link {
  text-decoration: none;
  display: block;
  width: 500px;
  flex-shrink: 0;
}
@media (min-width: 769px) {
  .events-grid--columned .event-card-link {
    width: auto;
  }
}

.event-card {
  background-color: white;
  padding: 0;
  border-radius: 10px;
  min-height: 250px;
  transition: transform 0.2s, box-shadow 0.2s;
  position: relative;
  overflow: hidden;
}

.event-card > *:not(.event-image) {
  padding: 0 25px;
}

.event-card > h3.event-title {
  padding-top: 20px;
}

.event-card > .event-excerpt,
.event-card > .event-meta:last-of-type {
  padding-bottom: 25px;
}

.event-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
}

.event-card.no-date {
  border: 2px solid #FF9800;
}

.event-warning {
  background-color: #FF9800;
  color: white;
  padding: 5px 10px;
  border-radius: 5px;
  font-size: 0.85rem;
  font-weight: bold;
  display: inline-block;
  margin-bottom: 10px;
}

.event-title {
  color: var(--wp--preset--color--ash-grey);
  margin: 0 0 15px 0;
  font-size: 1.4rem;
  line-height: 1.3;
}

/* Event meta sidebar — used on individual event pages (an-events template) */
.event-meta-sidebar {
  margin: 15px 0 35px;
  font-size: 1.6rem;
  font-weight: bold;
  line-height: 1.8;
}
.event-meta-sidebar .event-date,
.event-meta-sidebar .event-time,
.event-meta-sidebar .event-location {
  display: block;
}

.event-meta {
  background-color: #f5f5f5;
  padding: 20px 12px 12px;
  padding-top: 20px !important;
  border-radius: 5px;
  margin-bottom: 15px;
  font-size: 1.5rem;
  font-weight: bold;
  color: var(--wp--preset--color--ash-grey);
}

.event-meta > div {
  margin: 5px 0;
}

.event-date,
.event-time,
.event-location {
  display: flex;
  align-items: center;
  gap: 8px;
}

.event-image {
  margin: 0;
  width: 100%;
  aspect-ratio: 16/9;
  overflow: hidden;
  background-color: #f0f0f0;
}

.event-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.event-excerpt {
  color: var(--wp--preset--color--ash-grey);
  margin: 10px 0 0 0;
  font-size: 0.95rem;
  line-height: 1.4;
}

