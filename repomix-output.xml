#can_embed_form form.new_response li.control-group.checkbox_group_wrap span.controls.check_radio_field {
    display: flex !important;
    align-items: center !important;
    float: none !important;
}

#can_embed_form form.new_response li.control-group.checkbox_group_wrap label.checkbox {
    font-size: 18px !important;
    font-weight: bold !important;
    color: #000000 !important;
    display: flex !important;
    align-items: center !important;
    gap: 6px !important;
    margin: 0 !important;
