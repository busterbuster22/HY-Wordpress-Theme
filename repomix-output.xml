    margin: 0 !important;
    padding: 0 !important;
}

/* Hide labels — placeholders provide context */
.wpcf7-form label {
    display: none !important;
}

/* Shadow-box inputs */
.wpcf7-form input[type="text"],
.wpcf7-form input[type="email"],
.wpcf7-form textarea {
