/* ========================================
   LAYOUT & CONTAINERS
   ======================================== */

.wp-site-blocks {
    width: 100%;
    max-width: 100%;
}

/* Constrain content inside full-width sections */
.full-width-homepage .wp-block-columns,
.full-width-homepage > .wp-block-heading,
.full-width-homepage > .wp-block-paragraph,
.full-width-homepage > .petition-row,
